{
  "name": "trailforge",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "up": "docker compose up --build",
    "down": "docker compose down",
    "logs": "docker compose logs -f",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build && npm --prefix backend run build",
    "test": "npm --prefix backend test && npm --prefix frontend test",
    "test:integration:db": "npm --prefix backend run test:integration:db",
    "migrate": "npm --prefix backend run migrate:up",
    "migrate:down": "npm --prefix backend run migrate:down",
    "seed": "npm --prefix backend run seed"
  }
}
