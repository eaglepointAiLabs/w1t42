# Root compose defaults
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=trailforge
MYSQL_USER=trailforge
MYSQL_PASSWORD=trailforge

BACKEND_PORT=3000
FRONTEND_PORT=5173

DB_HOST=mysql
DB_PORT=3306
DB_NAME=trailforge
DB_USER=trailforge
DB_PASSWORD=trailforge

SESSION_SECRET=change-me-in-production
SESSION_TTL_HOURS=168
PROFILE_ENCRYPTION_KEY=trailforge-local-encryption-key
WECHAT_RECON_SECRET=trailforge-recon-secret
WORKER_POLL_INTERVAL_MS=5000
ORDER_AUTO_CANCEL_MINUTES=30
INGESTION_DROP_DIR=./ingestion_drop
INGESTION_SCAN_INTERVAL_MINUTES=1
INGESTION_RATE_LIMIT_PER_MINUTE=30
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
